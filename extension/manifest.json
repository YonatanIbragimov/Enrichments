{
  "manifest_version": 3,
  "name": "Rev Whisper Enrichment Bridge",
  "description": "Bridges the Rev Whisper GitHub Pages site to the local enrichment listener running on :5055.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:5055/*",
    "http://localhost:5055/*",
    "https://yonatanibragimov.github.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://yonatanibragimov.github.io/*",
        "file:///*/Enrichments/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Rev Whisper — enrichment bridge",
    "default_popup": "popup.html"
  }
}
